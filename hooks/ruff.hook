#!/bin/bash
uv run ruff format --exit-non-zero-on-format .
if [ $? -ne 0 ]; then
    echo "Code formatting issues detected. Please fix the issues before committing."
    exit 1
fi
uv run ruff check --fix --exit-non-zero-on-fix .
if [ $? -ne 0 ]; then
    echo "Linting issues detected. Please fix the issues before committing."
    exit 1
fi
